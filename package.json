{
  "name": "ai-bug-scanner",
  "version": "0.0.1",
  "description": "AI-powered security scanner for Rust projects (CLI)",
  "type": "module",
  "bin": {
    "ai-bug-scanner": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "eval": "tsx src/cli.ts evaluate",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "test": "node --import tsx --test test/*.test.ts",
    "clean": "rm -rf dist"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "globby": "^14.0.2",
    "openai": "^4.70.0",
    "ora": "^8.1.0",
    "p-limit": "^6.1.0",
    "smol-toml": "^1.3.1",
    "tree-sitter": "^0.22.4",
    "tree-sitter-rust": "^0.24.0",
    "yaml": "^2.9.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
