# Default provider used if --provider is not passed
AI_BUG_SCANNER_PROVIDER=kimi

# --- OpenAI-compatible providers ---
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2.6

GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4.5

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-sonnet-4

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
# deepseek-chat (V3, general) or deepseek-reasoner (R1, reasoning)
DEEPSEEK_MODEL=deepseek-chat

MIMO_API_KEY=
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
# Mimo has no safe default — set this to a real model id from the Mimo docs.
MIMO_MODEL=

# --- Anthropic-protocol endpoint for Mimo ---
MIMO_ANTHROPIC_BASE_URL=https://token-plan-cn.xiaomimimo.com/anthropic
